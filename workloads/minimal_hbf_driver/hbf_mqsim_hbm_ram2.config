# Minimal mixed-memory overlay config:
# - HBF backend: MQSim (Flash timing + internal hierarchy)
# - HBM backend: Ramulator2
#
# Partition mapping: partitions [0, 8) -> HBF, others -> HBM.

# -------------------------
# HBM (Ramulator2) backend
# -------------------------
-hbm_use_ramulator2 1
-hbm_ramulator2_wrapper external_wrappers/ramulator2_wrap/build/libramulator2_wrap.so
-hbm_ramulator2_config workloads/ramulator2/hbm2_16ch.yaml

# ---------------------
# HBF (MQSim) backend
# ---------------------
-hbf_use_mqsim 1
-hbf_mqsim_wrapper external_wrappers/mqsim_wrap/build/libmqsim_wrap.so
-hbf_mqsim_config workloads/mqsim/hbf_1p2TBs.xml

# HBF request granularity (bytes transferred per request).
-hbf_subpage_bytes 512

# Partition tagging: treat first 8 partitions as HBF.
-hbf_partition_start 0
-hbf_partition_count 8
-hbf_random_access 0

# Request-level trace labeling each request as HBF/HBM.
-hbf_request_trace 1
-hbf_request_trace_file hw_run/traces_jenius/minimal_mix_mqsim_ram2/hbf_requests.trace
-hbf_request_trace_limit 0
