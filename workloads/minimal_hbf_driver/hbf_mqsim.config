# Minimal HBF overlay config for smoke tests (MQSim backend).
#
# This enables MQSim as the HBF backend via dlopen (libmqsim_wrap.so), while
# keeping the existing request tagging + tracing knobs.

# Treat all memory partitions as HBF for a deterministic smoke test.
-hbf_partition_start 0
-hbf_partition_count 8

# Disable random tagging (partition tagging only).
-hbf_random_access 0

# Dump a request-level trace labeling each request as HBF/HBM.
-hbf_request_trace 1
-hbf_request_trace_file hw_run/traces_jenius/minimal_hbf_driver_mqsim/hbf_requests.trace
-hbf_request_trace_limit 0

# Optionally override latencies (0 = inherit HBM).
-hbf_dram_latency 0
-hbf_l2_rop_latency 0

# MQSim backend (shared instance across partitions).
-hbf_use_mqsim 1
-hbf_mqsim_wrapper external_wrappers/mqsim_wrap/build/libmqsim_wrap.so
-hbf_mqsim_config workloads/mqsim/hbf_1p2TBs.xml

# MQSim flash access granularity (bytes transferred per request).
-hbf_subpage_bytes 512
