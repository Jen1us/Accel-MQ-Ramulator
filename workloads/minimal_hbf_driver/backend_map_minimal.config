# Minimal backend-map smoke test overlay.
-hbm_use_ramulator2 0
-hbf_use_mqsim 0
-hbf_partition_count 0
-hbf_random_access 0
-hbf_request_trace 1
-hbf_request_trace_file hw_run/traces_jenius/minimal_hbf_driver/backend_map_requests.trace
-hbf_request_trace_limit 0
-mem_backend_map_file workloads/minimal_hbf_driver/backend_map_minimal.txt
-mem_backend_map_default unspecified
