# HBF peak-bandwidth overlay for QV100-SASS style configs
#
# Goal (physical targets):
# - tREAD = 20us
# - tPROG = 150us
# - tERASE = 1ms
# - Peak BW per stack = 1.2 TB/s
#
# Assumptions for this overlay:
# - core clock = 1132 MHz  (see -gpgpu_clock_domains in QV100-SASS configs)
# - gpgpu_n_mem = 32 partitions
# - Assumption: 4 stacks total, evenly mapped onto 32 partitions
#   -> partitions_per_stack = 32 / 4 = 8
#
# Notes:
# - Timing knobs are in simulator "global cycles" (same time base as gpu_tot_sim_cycle).
# - Bandwidth is enforced by a serialized per-partition link in hbf_t.

# Enforce 32 memory partitions (4 stacks * 8 partitions/stack).
# This lets us run the same overlay on top of configs that default to fewer
# partitions (e.g., SM86_RTX3070 defaults to 16).
-gpgpu_n_mem 32

# Enable HBF on all memory partitions (HBM is bypassed for off-chip requests).
-hbf_partition_start 0
-hbf_partition_count 32

# Keep default placement policies disabled (partition-based only).
-hbf_random_access 0
-hbf_addr_range_size 0

# Flash geometry.
-hbf_page_bytes 16384
# For max-bandwidth experiments we treat each request as a full page transfer
# (Flash reads are page-granular). This reduces the amount of MLP required to
# reach the peak link bandwidth under long tREAD latencies.
-hbf_subpage_bytes 16384
-hbf_block_pages 2748
# Internal parallelism (die * plane).
# With long tREAD, achieving peak link bandwidth requires enough independent
# planes to keep the link fed (Little's law). This overlay intentionally uses a
# high plane count so the *configured* link BW becomes the bottleneck.
-hbf_dies_per_channel 128
-hbf_planes_per_die 4

# Timing (converted using cycles = us * core_freq_MHz, core_freq_MHz=1132).
-hbf_t_read 22640          # 20us
-hbf_t_prog 169800         # 150us
-hbf_t_erase 1132000       # 1ms

# Bandwidth (1.2 TB/s per stack, 8 partitions/stack):
# per-partition bytes/cycle ~= 1.2e12 / (8 * 1.132e9) ~= 132.6
# NOTE: With an integer-cycle link model, the steady-state throughput is
#       quantized to subpage_bytes / ceil(subpage_bytes / bw). With
#       subpage_bytes=16384 and bw=133, xfer_cycles=124, yielding ~132 B/cycle
#       per partition (close to the configured target).
-hbf_channel_bytes_per_cycle 133

# Concurrency / buffering.
-hbf_max_outstanding 8192
-hbf_write_buffer_entries 16384
-hbf_posted_write_ack_latency 1

# Increase per-SM thread capacity to allow more concurrent warps in flight.
# This is a "peak BW" experiment knob (it increases the maximum number of
# resident warps), so the long HBF tREAD can be hidden enough to reach the
# configured link bandwidth.
-gpgpu_shader_core_pipeline 2048:32

# System-level buffering: with very long tREAD, small partition queues can
# throttle the issue rate and prevent reaching the configured peak bandwidth.
# These knobs are safe for microbenchmarks; dial them back for "realistic"
# GPU pipeline constraints.
-gpgpu_dram_partition_queues 256:256:256:256
-gpgpu_dram_return_queue_size 1024

# L2 miss handling: long tREAD requires high MLP to reach peak bandwidth.
# Increase MSHR entries / miss queue depth so the core can keep many HBF page
# reads in flight.
-gpgpu_cache:dl2 S:64:128:16,L:T:f:N:P,A:2048:4,256:0,32

# L1D miss handling: the default SM86 config has a relatively small L1 MSHR,
# which can throttle request injection under very long HBF tREAD. Increase the
# MSHR entries and miss queue depth to allow deeper memory-level parallelism
# (MLP) in max-bandwidth microbenchmarks.
-gpgpu_cache:dl1 S:4:128:256,L:T:f:N:L,A:8192:48,256:0,32

# Avoid false-positive deadlocks under long HBF stalls / bandwidth queueing.
-gpgpu_deadlock_detect_interval 10000000
