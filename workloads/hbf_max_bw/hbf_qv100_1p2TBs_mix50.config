# HBF+HBM mixed overlay (50% random tagging) for the max-bandwidth microbench.
#
# This is identical to `hbf_qv100_1p2TBs.config` but enables per-request random
# tagging so some off-chip requests still go to the existing HBM/DRAM backend.
#
# NOTE: `-hbf_random_access` overrides partition-based tagging.

# -----------------------------------------------------------------------------
# Topology / placement
# -----------------------------------------------------------------------------
-gpgpu_n_mem 32
-hbf_partition_start 0
-hbf_partition_count 32

# Mix: random per-request HBF tagging (the rest go to HBM).
-hbf_random_access 1
-hbf_random_access_percent 50
-hbf_random_access_seed 0

# Disable other placement policies.
-hbf_addr_range_size 0

# -----------------------------------------------------------------------------
# Flash geometry + timing (Phase-1 perf model)
# -----------------------------------------------------------------------------
-hbf_page_bytes 16384
-hbf_subpage_bytes 16384
-hbf_block_pages 2748
-hbf_dies_per_channel 128
-hbf_planes_per_die 4

# Timing (cycles = us * core_freq_MHz, core_freq_MHz=1132).
-hbf_t_read 22640          # 20us
-hbf_t_prog 169800         # 150us
-hbf_t_erase 1132000       # 1ms

# Bandwidth (target: ~1.2 TB/s per stack, 4 partitions/stack).
-hbf_channel_bytes_per_cycle 265

# -----------------------------------------------------------------------------
# Concurrency / buffering
# -----------------------------------------------------------------------------
-hbf_max_outstanding 8192
-hbf_write_buffer_entries 16384
-hbf_posted_write_ack_latency 1

# Peak-BW knob: allow more resident warps so the long HBF tREAD can be hidden.
-gpgpu_shader_core_pipeline 2048:32

-gpgpu_dram_partition_queues 256:256:256:256
-gpgpu_dram_return_queue_size 1024

# L2 miss handling: allow high MLP so long tREAD does not artificially cap BW.
-gpgpu_cache:dl2 S:64:128:16,L:T:f:N:P,A:2048:4,256:0,32

# L1D miss handling: increase MSHR/miss queue to support high MLP under long
# tREAD in max-bandwidth experiments.
-gpgpu_cache:dl1 S:4:128:256,L:T:f:N:L,A:8192:48,256:0,32

-gpgpu_deadlock_detect_interval 10000000
