# MLPerf BERT (trace-driven) overlay: HBM-only using Accel-Sim internal DRAM
#
# This disables both external backends:
#   - HBF(MQSim)
#   - HBM(Ramulator2)
#
# Usage:
#   accel-sim.out -config <bert gpgpusim.config> -config this_file -trace <kernelslist.g>

# Disable all HBF tagging.
-hbf_partition_start 0
-hbf_partition_count 0
-hbf_random_access 0
-hbf_addr_range_size 0
-hbf_request_trace 0

# Use internal backends.
-hbf_use_mqsim 0
-hbm_use_ramulator2 0

