# MLPerf BERT (trace-driven) overlay: mixed HBF(MQSim)+HBM(Ramulator2)
#
# Policy: partitions [0,8) -> HBF, the rest -> HBM.
#
# Usage:
#   accel-sim.out -config <bert gpgpusim.config> -config this_file -trace <kernelslist.g>

-hbf_partition_start 0
-hbf_partition_count 8
-hbf_random_access 0
-hbf_addr_range_size 0

# Enable per-request tagging trace (written relative to the run directory).
-hbf_request_trace 1
-hbf_request_trace_file sim_run_mlperf_cosim/bert_mixed/hbf_requests.trace
-hbf_request_trace_limit 0

# External HBF backend (MQSim).
-hbf_use_mqsim 1
-hbf_mqsim_wrapper external_wrappers/mqsim_wrap/build/libmqsim_wrap.so
-hbf_mqsim_config workloads/mqsim/hbf_1p2TBs.xml

# External HBM backend (Ramulator2).
-hbm_use_ramulator2 1
-hbm_ramulator2_wrapper external_wrappers/ramulator2_wrap/build/libramulator2_wrap.so
-hbm_ramulator2_config workloads/ramulator2/hbm2_16ch.yaml
