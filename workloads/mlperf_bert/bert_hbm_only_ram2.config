# MLPerf BERT (trace-driven) overlay: HBM-only using Ramulator2 backend
#
# Usage:
#   accel-sim.out -config <bert gpgpusim.config> -config this_file -trace <kernelslist.g>

# Disable all HBF tagging.
-hbf_partition_start 0
-hbf_partition_count 0
-hbf_random_access 0
-hbf_addr_range_size 0
-hbf_request_trace 0

# External HBM backend (Ramulator2).
-hbm_use_ramulator2 1
-hbm_ramulator2_wrapper external_wrappers/ramulator2_wrap/build/libramulator2_wrap.so
-hbm_ramulator2_config workloads/ramulator2/hbm2_16ch.yaml

# Ensure MQSim is disabled.
-hbf_use_mqsim 0

