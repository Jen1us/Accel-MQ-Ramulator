# MLPerf BERT (trace-driven) overlay: HBF-only using MQSim backend
#
# Usage:
#   accel-sim.out -config <bert gpgpusim.config> -config this_file -trace <kernelslist.g>

# Tag all memory partitions as HBF (RTX3070 config uses -gpgpu_n_mem 16).
-hbf_partition_start 0
-hbf_partition_count 16
-hbf_random_access 0
-hbf_addr_range_size 0
-hbf_request_trace 0

# External HBF backend (MQSim).
-hbf_use_mqsim 1
-hbf_mqsim_wrapper external_wrappers/mqsim_wrap/build/libmqsim_wrap.so
-hbf_mqsim_config workloads/mqsim/hbf_1p2TBs.xml

# Ensure Ramulator2 is disabled.
-hbm_use_ramulator2 0

