# FlashAttention v2 (minimal driver) overlay config.
#
# When a request is tagged as HBF, the simulator uses Flash-style timing
# parameters (`-hbf_t_read`, `-hbf_subpage_bytes`, etc.) instead of DRAM timing.

# Random per-request HBF tagging (overrides partition tagging).
-hbf_partition_start 0
-hbf_partition_count 0
-hbf_random_access 1
-hbf_random_access_percent 50
-hbf_random_access_seed 0

# Dump a request-level trace labeling each request as HBF/HBM.
-hbf_request_trace 1
-hbf_request_trace_file hbf_requests.trace
-hbf_request_trace_limit 0

# Optionally override latencies (0 = inherit HBM).
-hbf_dram_latency 0
-hbf_l2_rop_latency 0
